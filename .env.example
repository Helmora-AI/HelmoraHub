# Helmora Hub
PORT=20800
HOST=127.0.0.1

# Production / Docker / Pterodactyl: bind all interfaces
# HOST=0.0.0.0
# HELMORA_PUBLIC=1
# NODE_ENV=production

# Panels (Pterodactyl) often inject SERVER_PORT — Helmora Hub maps it to PORT automatically
# SERVER_PORT=20800

# Data directory (SQLite + runtime-config.json). Default: ./data
# DATA_DIR=./data
# Pterodactyl tip: DATA_DIR=/home/container/data

# Unified /v1 client keys: prefer Settings → API keys (hel_dev_ / hel_pro_).
# Legacy single env still seeds one key on first boot if api_keys empty:
# HELMORA_API_KEY=hel_dev_...
# Legacy fallback: CTRLHUB_API_KEY=ctrl_dev_...

# --- Admin auth (Settings + /api/*) ---
# First visit to /settings creates password (bootstrap).
# Optional env (panel File Manager / .env):
# HELMORA_ADMIN_PASSWORD=your-admin-password
# HELMORA_ADMIN_TOKEN=helmora-admin-...
# HELMORA_SESSION_SECRET=random-hex
# HELMORA_COOKIE_SECURE=1
# Legacy CTRLHUB_* vars still accepted as fallback.

# RTK token saver (tool-output compression). Default: follow mode profile (smart/coding/economy/premium on).
# HELMORA_RTK=1
# HELMORA_RTK=0

# Guardrail A (input block/redact + output secret redact). Default: on.
# HELMORA_GUARDRAIL=1
# HELMORA_GUARDRAIL=0

# Master encryption key (AES-256-GCM). Can also be set in Settings UI when using SQL.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=

# --- Storage preference ---
# Prefer Settings UI: http://HOST:PORT/settings
#   Local (default) = SQLite (control + workspace on this machine)
#   SQL             = Hybrid: Supabase control + local vault/workspace SQLite
# Saved to data/runtime-config.json
#
# Legacy env (only used if runtime-config.json does not exist yet):
# STORAGE_BACKEND=local|sql

# Rate store: memory (default) | redis
# RATE_BACKEND=memory
# REDIS_URL=rediss://default:TOKEN@HOST:6379

# Optional defaults for SQL mode (or enter in Settings UI)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Optional default upstream (OpenAI-compatible)
# UPSTREAM_BASE_URL=https://api.openai.com/v1
# UPSTREAM_API_KEY=sk-...
# UPSTREAM_MODEL=gpt-4o-mini

# --- OAuth PKCE (Claude / Codex Connect) ---
# Public Hub origin used as IdP redirect_uri (…/api/oauth/callback). Required for Connect.
# HELMORA_PUBLIC_URL=https://hub.example.com
# SPA origin for post-callback redirect allowlist (…/providers?oauth=ok|error). Required for Connect.
# HELMORA_FRONTEND_URL=https://app.example.com
# Optional client overrides (defaults are encapsulated Claude/Codex CLI clients):
# HELMORA_OAUTH_CLAUDE_CLIENT_ID=
# HELMORA_OAUTH_CLAUDE_CLIENT_SECRET=
# HELMORA_OAUTH_CODEX_CLIENT_ID=
# HELMORA_OAUTH_CODEX_CLIENT_SECRET=

# --- Cloudflare Tunnel (named / token connector) ---
# Prefer Settings UI: http://HOST:PORT/settings → Cloudflare Tunnel
# Pterodactyl (generic egg): File Manager → data/cloudflare-tunnel.token (one line)
# Or set env (env token overrides file + Settings):
# CLOUDFLARE_TUNNEL_TOKEN=eyJ...
# CLOUDFLARE_TUNNEL_HOSTNAME=hub.example.com
# CLOUDFLARE_TUNNEL_AUTO_START=1
# Optional transport (default http2 — better on restrictive panels):
# TUNNEL_TRANSPORT_PROTOCOL=http2
# TUNNEL_AUTO_INSTALL_CLOUDFLARED=1
# CLOUDFLARED_BIN_PATH=/home/container/.cloudflared/bin/cloudflared
# TUNNEL_ENABLED=1
# CLOUDFLARED_LOG_PATH=./cloudflare/cloudflared.log
# CLOUDFLARED_PID_PATH=./cloudflare/cloudflared.pid